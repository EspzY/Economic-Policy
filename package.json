{
  "name": "economic-policy-study-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "set \"ASTRO_TELEMETRY_DISABLED=1\" && astro dev",
    "build": "set \"ASTRO_TELEMETRY_DISABLED=1\" && astro build",
    "preview": "set \"ASTRO_TELEMETRY_DISABLED=1\" && astro preview",
    "check": "set \"ASTRO_TELEMETRY_DISABLED=1\" && astro check",
    "sync:materials": "node scripts/sync-materials.mjs",
    "predev": "npm run sync:materials",
    "prebuild": "npm run sync:materials"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8"
  }
}
